generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

model Ad {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price       Float
  //tag String
  //image
  createAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
